# =============================================================================
# PLOT TO PEAK — JOBBER API (BACKEND) CREDENTIALS
# -----------------------------------------------------------------------------
# 1. Copy this file to ".env"  (do NOT commit the real .env — it is gitignored)
# 2. Fill in the values from your Jobber Developer app.
#    Get them at: https://developer.getjobber.com  →  My Apps  →  (your app)
# =============================================================================

# --- From your Jobber Developer App (App Settings) ---------------------------
JOBBER_CLIENT_ID=<<PASTE_JOBBER_APP_CLIENT_ID>>
JOBBER_CLIENT_SECRET=<<PASTE_JOBBER_APP_CLIENT_SECRET>>

# The Redirect/Callback URL — must EXACTLY match what you entered on the Jobber app.
# For local testing you can use: http://localhost:3000/api/jobber/callback
JOBBER_REDIRECT_URI=<<PASTE_YOUR_BACKEND_URL>>/api/jobber/callback

# --- API version you build against (see developer.getjobber.com/docs) --------
# Format: YYYY-MM-DD. Update when you intentionally move to a newer schema.
JOBBER_API_VERSION=2023-11-15

# --- App security ------------------------------------------------------------
# Any long random string. Used to sign the OAuth "state" value and sessions.
SESSION_SECRET=<<GENERATE_A_LONG_RANDOM_STRING>>

# Where the demo stores the OAuth tokens after you connect.
# NOTE: a local JSON file is fine for testing only. In production use a database
# or a managed secret store instead.
TOKEN_STORE_PATH=./.jobber-tokens.json

# Port for the example server
PORT=3000
